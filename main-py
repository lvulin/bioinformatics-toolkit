import argparse

def main():
    parser = argparse.ArgumentParser(description="Bioinformatics Toolkit")
    parser.add_argument("--task", required=True, help="Task to run")
    parser.add_argument("--seq1", required=True, help="First sequence")
    parser.add_argument("--seq2", help="Second sequence")

    args = parser.parse_args()

    print("Task:", args.task)
    print("Sequence 1:", args.seq1)
    if args.seq2:
        print("Sequence 2:", args.seq2)

if __name__ == "__main__":
    main()
